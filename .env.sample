# AI Agent 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ==================== API 配置 ====================
# API 服务提供商的基础 URL
# 常见选项：
#   - https://api.openai.com/v1 (OpenAI 官方)
#   - https://api.qnaigc.com/v1 (千问)
#   - https://openrouter.ai/api/v1 (OpenRouter)
#   - https://generativelanguage.googleapis.com/v1beta/openai/ (Google Gemini)
#   - https://integrate.api.nvidia.com/v1 (NVIDIA)
#   - http://172.21.240.16:8000/v1 (本地服务)
BASE_URL=https://api.openai.com/v1

# 模型名称
# 根据选择的 API 服务商选择相应模型：
#   OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
#   千问: minimax/minimax-m2.1, z-ai/glm-4.7, deepseek/deepseek-v3.2-251201
#   OpenRouter (免费): z-ai/glm-4.5-air:free, stepfun/step-3.5-flash:free
#   Google Gemini: gemini-3-flash-preview, gemini-2.5-pro
#   NVIDIA: deepseek-ai/deepseek-v3.2, meta/llama-3.3-70b-instruct
MODEL=gpt-3.5-turbo

# API 密钥
# 从对应的平台获取 API Key
API_KEY=your-api-key-here

# 兼容性：以下变量会被自动读取
# OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# NV_API_KEY=your-nvidia-api-key

# ==================== 代理配置 ====================
# HTTP 代理地址（可选，用于访问需要代理的 API）
# 格式: http://proxy-host:port
HTTP_PROXY=http://127.0.0.1:10808

# HTTPS 代理地址（可选，默认与 HTTP_PROXY 相同）
HTTPS_PROXY=http://127.0.0.1:10808

# ==================== 向量存储配置 ====================
# Faiss 向量数据库元数据文件路径
VECTRA_META_PATH=./vectorstore.meta.json

# 嵌入模型（用于语义搜索）
# 选项: Xenova/paraphrase-multilingual-MiniLM-L12-v2 (默认，多语言)
#       Xenova/text2vec-base-chinese-sentence (中文优化)
EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# Chroma 向量数据库 URL（可选）
CHROMA_URL=http://localhost:8000

# Chroma 集合名称（可选）
CHROMA_COLLECTION=rag_docs_v2

# ==================== RAG 配置 ====================
# 检索返回的文档数量
RETRIEVAL_K=10

# 搜索类型
# 选项: similarity (相似度), mmr (最大边际相关性)
SEARCH_TYPE=similarity

# ==================== 使用说明 ====================
# 1. 复制此文件: cp .env.sample .env
# 2. 编辑 .env 文件，填入你的实际配置
# 3. 运行: node test.js (或 test2.js, test3.js, test4.js, test5.js)

# ==================== 不同文件说明 ====================
# test.js  - 原生 fetch 实现，零依赖，适合学习
# test2.js - OpenAI SDK 实现，简洁易用
# test3.js - LangChain 流式实现，手动处理工具调用
# test4.js - LangChain Agent 实现，自动处理工具调用（推荐）
# test5.js - LangGraph 状态机实现，最完整的生产级方案